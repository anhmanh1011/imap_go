# Telegram (from my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=replace_me
TG_SESSION_FILE=./main.session

# Channels — @username form only (v1; numeric IDs require dialogs lookup, deferred)
TG_INPUT_CHANNEL=@txt_output
TG_OUTPUT_CHANNEL=@valid

# Checker
WORKERS=20000
PROXIES_FILE=./proxies/rotating.txt
# PROXY_URL=https://example.com/list   # mutually exclusive with PROXIES_FILE
PROXY_REFRESH=10m
DB_PATH=./Servers.db
WORK_DIR=./tgbot_workdir

# State
STATE_DB=./tgbot_state.db
